# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database - MySQL (AWS RDS)
DATABASE_URL=mysql://admin:your_password@academic.cd6qi206u377.eu-north-1.rds.amazonaws.com:3306/academic

# Database - MongoDB Atlas (legacy - remove after SQL migration)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/academic

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# Analytics Service
ANALYTICS_SERVICE_URL=http://localhost:8001
ANALYTICS_API_KEY=analytics-service-api-key

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# Email (Optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=email-password
EMAIL_FROM=Academic Platform <noreply@example.com>
